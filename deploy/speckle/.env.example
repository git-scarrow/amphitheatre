# /srv/speckle/.env — copy to .env on the VM, fill with generated secrets (mode 600).
# Generate secrets with: openssl rand -hex N
CANONICAL_URL=https://speckle-review.scarrow.tailnet
TS_BIND=100.64.0.10                 # the node's tailnet IP; Caddy publishes ONLY here
SESSION_SECRET=                     # openssl rand -hex 32
POSTGRES_PASSWORD=                  # openssl rand -hex 24
S3_ACCESS_KEY=                      # openssl rand -hex 12
S3_SECRET_KEY=                      # openssl rand -hex 32
